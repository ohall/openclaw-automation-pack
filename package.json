{
  "name": "openclaw-automation-pack",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Pragmatic scripts for OpenClaw + Home Assistant ops.",
  "scripts": {
    "lint": "node --check scripts/*.mjs",
    "format": "prettier --write \"scripts/**/*.mjs\" \"test/**/*.mjs\"",
    "format:check": "prettier --check \"scripts/**/*.mjs\" \"test/**/*.mjs\"",
    "lint:eslint": "eslint \"scripts/**/*.mjs\" \"test/**/*.mjs\"",
    "test": "node --test test/*.mjs",
    "ci": "npm run format:check && npm run lint:eslint && npm run lint && npm run test",
    "hacs:update": "node scripts/ha-hacs-update.mjs",
    "ha:scan-updates": "node scripts/ha-scan-update-entities.mjs",
    "hubitat:disable-orphans": "node scripts/ha-disable-orphans.mjs",
    "ha:logscan": "bash scripts/ha-log-scan.sh"
  },
  "dependencies": {
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "eslint": "^9.17.0",
    "@eslint/js": "^9.17.0",
    "globals": "^16.0.0"
  }
}
